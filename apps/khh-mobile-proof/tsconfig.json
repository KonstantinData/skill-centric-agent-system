{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@scas/tenant-workbench-domain": [
        "../../packages/tenant-workbench-domain/src/index.ts"
      ],
      "@scas/tenant-workbench-domain/*": [
        "../../packages/tenant-workbench-domain/src/*.ts"
      ],
      "@scas/tenant-workbench-client": [
        "../../packages/tenant-workbench-client/src/index.ts"
      ],
      "@scas/tenant-workbench-client/*": [
        "../../packages/tenant-workbench-client/src/*.ts"
      ],
      "@scas/tenant-workbench-ui": [
        "../../packages/tenant-workbench-ui/src/index.ts"
      ]
    }
  },
  "include": [
    "App.tsx",
    "app/**/*.tsx",
    "src/**/*.ts",
    "types/**/*.d.ts",
    "../../packages/tenant-workbench-domain/src/**/*.ts",
    "../../packages/tenant-workbench-client/src/**/*.ts",
    "../../packages/tenant-workbench-ui/src/**/*.ts"
  ]
}
