{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:write-approval-policy:0.1.0",
  "title": "SCAS Write Approval Policy",
  "type": "object",
  "required": [
    "policy_id",
    "version",
    "applies_to_tools",
    "required_data_scope",
    "required_profile_policy",
    "allowed_operations",
    "approval_fields",
    "rollback"
  ],
  "additionalProperties": false,
  "properties": {
    "policy_id": {
      "const": "write-approval-required"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "applies_to_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "const": "filesystem-write"
      },
      "uniqueItems": true
    },
    "required_data_scope": {
      "const": "repository-write"
    },
    "required_profile_policy": {
      "const": "write-approval-required"
    },
    "allowed_operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "const": "write_text_file"
      },
      "uniqueItems": true
    },
    "approval_fields": {
      "type": "array",
      "items": {
        "enum": ["approval_id", "approved_by", "approved_at", "policy_id"]
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "rollback": {
      "type": "object",
      "required": ["new_file_strategy", "overwrite_strategy", "metadata_only_first_slice"],
      "additionalProperties": false,
      "properties": {
        "new_file_strategy": {
          "const": "delete_created_file"
        },
        "overwrite_strategy": {
          "const": "restore_previous_content"
        },
        "metadata_only_first_slice": {
          "const": true
        }
      }
    }
  }
}
