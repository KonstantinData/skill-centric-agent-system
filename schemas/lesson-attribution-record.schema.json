{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:lesson-attribution-record:0.1.0",
  "title": "SCAS Lesson Attribution Record",
  "type": "object",
  "required": [
    "contract_version",
    "record_id",
    "run_id",
    "selection_record_id",
    "plan_id",
    "used_memory_ids",
    "ignored_memory_ids",
    "context_fingerprint",
    "outcome",
    "success_criteria",
    "error_classification",
    "ranking_feedback",
    "feedback_effect",
    "authority_delta"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "0.1.0"
    },
    "record_id": {
      "$ref": "#/$defs/id"
    },
    "run_id": {
      "$ref": "#/$defs/id"
    },
    "selection_record_id": {
      "$ref": "#/$defs/id"
    },
    "plan_id": {
      "$ref": "#/$defs/id"
    },
    "used_memory_ids": {
      "$ref": "#/$defs/stringList"
    },
    "ignored_memory_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "context_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "outcome": {
      "enum": [
        "succeeded",
        "failed",
        "neutral"
      ]
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "status",
          "evidence_uris"
        ],
        "additionalProperties": false,
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "met",
              "missed",
              "not_applicable"
            ]
          },
          "evidence_uris": {
            "$ref": "#/$defs/hetznerEvidenceList"
          }
        }
      }
    },
    "error_classification": {
      "type": "object",
      "required": [
        "error_class",
        "error_confidence",
        "classification_source",
        "error_evidence",
        "runtime_playbook"
      ],
      "additionalProperties": false,
      "properties": {
        "error_class": {
          "enum": [
            "F1_INEFFICIENCY_PATH",
            "F2_INTERFACE_CONTRACT_BREAKDOWN",
            "R8_POLICY_CONFLICT_CONTEXT_CONTAMINATION",
            "NONE"
          ]
        },
        "error_confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "classification_source": {
          "enum": [
            "rule_based_runtime_v1",
            "llm_judge_v1"
          ]
        },
        "error_evidence": {
          "type": "object"
        },
        "runtime_playbook": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ranking_feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "memory_id",
          "effect",
          "direction",
          "weight_delta",
          "context_fingerprint",
          "context_bound",
          "reason",
          "authority_delta"
        ],
        "additionalProperties": false,
        "properties": {
          "memory_id": {
            "type": "string",
            "minLength": 1
          },
          "effect": {
            "enum": [
              "ranking_adjustment",
              "planner_hint_adjustment"
            ]
          },
          "direction": {
            "enum": [
              "promote",
              "demote",
              "neutral"
            ]
          },
          "weight_delta": {
            "type": "number",
            "minimum": -0.2,
            "maximum": 0.2
          },
          "context_fingerprint": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "context_bound": {
            "const": true
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "authority_delta": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    "feedback_effect": {
      "const": "non_authoritative_ranking_only"
    },
    "authority_delta": {
      "type": "array",
      "maxItems": 0
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hetznerEvidenceList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^hetzner://runtime/.+"
      }
    }
  }
}
