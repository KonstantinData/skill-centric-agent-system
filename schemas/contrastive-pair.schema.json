{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:contrastive-pair:0.1.0",
  "title": "SCAS Semantic Drift Guard Contrastive Pairs",
  "type": "object",
  "required": [
    "contract_version",
    "guard_id",
    "owner",
    "authority_invariant",
    "default_on_match",
    "influence_classes",
    "contrastive_pairs"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "guard_id": {
      "const": "semantic-drift-guard"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "authority_invariant": {
      "const": "learned_context_not_authority"
    },
    "default_on_match": {
      "$ref": "#/$defs/gateDecision"
    },
    "influence_classes": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "max_automatic_effect",
          "automatic_authority_delta_allowed"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/$defs/influenceClass"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "max_automatic_effect": {
            "enum": [
              "retrieval_ordering",
              "planner_hint",
              "analyzer_prior",
              "candidate_ranking",
              "proposal_only"
            ]
          },
          "automatic_authority_delta_allowed": {
            "const": false
          }
        }
      }
    },
    "contrastive_pairs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "pair_id",
          "description",
          "positive_context",
          "forbidden_generalization",
          "expected_gate",
          "evidence_uris"
        ],
        "additionalProperties": false,
        "properties": {
          "pair_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "positive_context": {
            "$ref": "#/$defs/context"
          },
          "forbidden_generalization": {
            "type": "object",
            "required": [
              "environment",
              "risk_level",
              "authority_delta"
            ],
            "additionalProperties": false,
            "properties": {
              "environment": {
                "$ref": "#/$defs/environment"
              },
              "risk_level": {
                "$ref": "#/$defs/riskLevel"
              },
              "workflow_id": {
                "$ref": "#/$defs/identifier"
              },
              "principal_role": {
                "$ref": "#/$defs/identifier"
              },
              "task_type": {
                "$ref": "#/$defs/identifier"
              },
              "authority_delta": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "$ref": "#/$defs/authorityDelta"
                }
              }
            }
          },
          "expected_gate": {
            "$ref": "#/$defs/gateDecision"
          },
          "evidence_uris": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "authorityDelta": {
      "enum": [
        "tool_addition",
        "scope_expansion",
        "budget_increase",
        "validator_removal",
        "failure_mode_relaxation",
        "policy_exception",
        "data_access_expansion",
        "memory_scope_expansion",
        "knowledge_scope_expansion"
      ]
    },
    "context": {
      "type": "object",
      "required": [
        "environment",
        "risk_level"
      ],
      "additionalProperties": false,
      "properties": {
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "risk_level": {
          "$ref": "#/$defs/riskLevel"
        },
        "workflow_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_role": {
          "$ref": "#/$defs/identifier"
        },
        "task_type": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "environment": {
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "gateDecision": {
      "enum": [
        "allow_ranking_only",
        "freeze_prior",
        "needs_human_review",
        "needs_more_evidence",
        "reject"
      ]
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "influenceClass": {
      "enum": [
        "retrieval_only",
        "planner_hint",
        "analyzer_prior",
        "composer_candidate_bias",
        "golden_workflow_proposal",
        "policy_change_proposal",
        "scoped_exception_proposal"
      ]
    },
    "riskLevel": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    }
  }
}
