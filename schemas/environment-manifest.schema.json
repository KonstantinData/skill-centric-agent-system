{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:environment-manifest:0.1.0",
  "title": "SCAS Environment Separation Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "environments"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "environments": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/environment"
      }
    }
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "release_role",
        "cloudflare",
        "hetzner",
        "github_actions"
      ],
      "properties": {
        "name": {
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "release_role": {
          "enum": [
            "development",
            "rehearsal",
            "production"
          ]
        },
        "cloudflare": {
          "$ref": "#/$defs/cloudflare"
        },
        "hetzner": {
          "$ref": "#/$defs/hetzner"
        },
        "github_actions": {
          "$ref": "#/$defs/github_actions"
        }
      }
    },
    "cloudflare": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_name",
        "control_d1_database",
        "knowledge_r2_bucket",
        "memory_r2_bucket",
        "knowledge_vectorize_index",
        "memory_vectorize_index",
        "config_kv_namespace",
        "ingest_queue",
        "ingest_dead_letter_queue",
        "ai_gateway_id"
      ],
      "properties": {
        "worker_name": {
          "$ref": "#/$defs/resource_name"
        },
        "control_d1_database": {
          "$ref": "#/$defs/resource_name"
        },
        "knowledge_r2_bucket": {
          "$ref": "#/$defs/resource_name"
        },
        "memory_r2_bucket": {
          "$ref": "#/$defs/resource_name"
        },
        "knowledge_vectorize_index": {
          "$ref": "#/$defs/resource_name"
        },
        "memory_vectorize_index": {
          "$ref": "#/$defs/resource_name"
        },
        "config_kv_namespace": {
          "$ref": "#/$defs/resource_name"
        },
        "ingest_queue": {
          "$ref": "#/$defs/resource_name"
        },
        "ingest_dead_letter_queue": {
          "$ref": "#/$defs/resource_name"
        },
        "ai_gateway_id": {
          "$ref": "#/$defs/resource_name"
        }
      }
    },
    "hetzner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_database",
        "runtime_schema",
        "runtime_owner_role",
        "artifact_root"
      ],
      "properties": {
        "runtime_database": {
          "$ref": "#/$defs/postgres_identifier"
        },
        "runtime_schema": {
          "$ref": "#/$defs/postgres_identifier"
        },
        "runtime_owner_role": {
          "$ref": "#/$defs/postgres_identifier"
        },
        "artifact_root": {
          "type": "string",
          "pattern": "^/opt/scas/runtime(/[a-z0-9-]+)+$"
        }
      }
    },
    "github_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_name",
        "secret_prefix",
        "required_secrets"
      ],
      "properties": {
        "environment_name": {
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "secret_prefix": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "required_secrets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "resource_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "postgres_identifier": {
      "type": "string",
      "pattern": "^[a-z_][a-z0-9_]*$"
    }
  }
}
