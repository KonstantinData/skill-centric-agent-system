{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:memory-safety-evaluation:0.1.0",
  "title": "SCAS Memory Safety Evaluation Fixture",
  "type": "object",
  "required": [
    "contract_version",
    "evaluation_id",
    "semantic_drift_policy_path",
    "required_failure_classes",
    "metrics_thresholds",
    "cases"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "0.1.0"
    },
    "evaluation_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "semantic_drift_policy_path": {
      "type": "string",
      "minLength": 1
    },
    "allowed_memory_scope_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_policy_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_failure_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/failureClass"
      }
    },
    "metrics_thresholds": {
      "type": "object",
      "required": [
        "max_false_negative_rate",
        "max_false_positive_rate",
        "max_abstention_review_rate"
      ],
      "additionalProperties": false,
      "properties": {
        "max_false_negative_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_false_positive_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_abstention_review_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "gate",
          "failure_class",
          "expected_outcome",
          "description",
          "input"
        ],
        "additionalProperties": false,
        "properties": {
          "case_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "gate": {
            "enum": [
              "candidate_validation",
              "semantic_drift",
              "post_planning_invariant"
            ]
          },
          "failure_class": {
            "$ref": "#/$defs/failureClass"
          },
          "expected_outcome": {
            "enum": [
              "allow",
              "block"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "input": {
            "type": "object"
          }
        }
      }
    }
  },
  "$defs": {
    "failureClass": {
      "enum": [
        "positive_procedural_lesson",
        "tool_grant",
        "scope_grant",
        "policy_override",
        "validator_override",
        "task_subject_fact_as_memory",
        "environment_generalization",
        "risk_level_generalization",
        "secret_or_sensitive_content",
        "conflicting_lessons"
      ]
    }
  }
}
