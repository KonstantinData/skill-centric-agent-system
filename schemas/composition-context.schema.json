{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:composition-context:0.2.0",
  "title": "Composition Context Endpoint Contract",
  "description": "Request and response contract for POST /composition/context on the Cloudflare Control API.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request",
    "response"
  ],
  "properties": {
    "request": {
      "$ref": "#/$defs/request"
    },
    "response": {
      "$ref": "#/$defs/response"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "moduleKind": {
      "type": "string",
      "enum": [
        "skill",
        "instruction",
        "tool",
        "knowledge_scope",
        "data_scope",
        "memory_scope",
        "policy",
        "validator"
      ]
    },
    "skillRuntimeRole": {
      "type": "string",
      "enum": [
        "runtime",
        "non-runtime",
        "shared"
      ]
    },
    "moduleReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "version",
        "score"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/moduleKind"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string"
        },
        "runtime_role": {
          "$ref": "#/$defs/skillRuntimeRole"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "skill"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "runtime_role"
            ]
          }
        }
      ]
    },
    "moduleIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/moduleKind"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "runtime_role": {
          "$ref": "#/$defs/skillRuntimeRole"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "skill"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "runtime_role"
            ]
          }
        }
      ]
    },
    "policyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module",
        "effect",
        "reasons"
      ],
      "properties": {
        "module": {
          "$ref": "#/$defs/moduleIdentity"
        },
        "effect": {
          "type": "string",
          "enum": [
            "allow",
            "deny",
            "needs_clarification"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "graphValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_valid",
        "errors",
        "reachable_modules"
      ],
      "properties": {
        "is_valid": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reachable_modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleIdentity"
          }
        }
      }
    },
    "tenantAuthority": {
      "type": "object",
      "description": "Tenant-local authority snapshot used by the Composer to fail closed before emitting a runtime profile.",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "area_id",
        "hostname",
        "status",
        "direct_user_grants_allowed",
        "membership",
        "role_bundles",
        "data_sources",
        "allowed_knowledge_scopes",
        "allowed_data_scopes",
        "allowed_memory_scopes"
      ],
      "properties": {
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "area_id": {
          "$ref": "#/$defs/id"
        },
        "hostname": {
          "type": "object",
          "description": "D1-derived hostname authority that proves the request host belongs to the tenant.",
          "additionalProperties": false,
          "required": [
            "tenant_id",
            "hostname",
            "purpose",
            "expected_origin",
            "cloudflare_proxy_expected"
          ],
          "properties": {
            "tenant_id": {
              "$ref": "#/$defs/id"
            },
            "hostname": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
            },
            "purpose": {
              "type": "string",
              "minLength": 1
            },
            "expected_origin": {
              "type": "string",
              "minLength": 1
            },
            "cloudflare_proxy_expected": {
              "type": "boolean"
            }
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "setup",
            "active",
            "disabled",
            "archived"
          ]
        },
        "direct_user_grants_allowed": {
          "type": "boolean",
          "const": false
        },
        "membership": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "tenant_id",
            "principal_id",
            "status",
            "role_ids"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "tenant_id": {
              "$ref": "#/$defs/id"
            },
            "principal_id": {
              "$ref": "#/$defs/id"
            },
            "status": {
              "type": "string",
              "enum": [
                "invited",
                "active",
                "disabled"
              ]
            },
            "role_ids": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/id"
              },
              "minItems": 1,
              "uniqueItems": true
            }
          }
        },
        "role_bundles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "tenant_id",
              "capability_grants",
              "data_source_grants",
              "derived_runtime_modules"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/id"
              },
              "tenant_id": {
                "$ref": "#/$defs/id"
              },
              "capability_grants": {
                "$ref": "#/$defs/idArray"
              },
              "data_source_grants": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "data_source_id",
                    "access_modes"
                  ],
                  "properties": {
                    "data_source_id": {
                      "$ref": "#/$defs/id"
                    },
                    "access_modes": {
                      "$ref": "#/$defs/idArray"
                    }
                  }
                }
              },
              "derived_runtime_modules": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "skills",
                  "workflows",
                  "tools",
                  "policies",
                  "validators"
                ],
                "properties": {
                  "skills": {
                    "$ref": "#/$defs/idArray"
                  },
                  "workflows": {
                    "$ref": "#/$defs/idArray"
                  },
                  "tools": {
                    "$ref": "#/$defs/idArray"
                  },
                  "policies": {
                    "$ref": "#/$defs/idArray"
                  },
                  "validators": {
                    "$ref": "#/$defs/idArray"
                  }
                }
              }
            }
          }
        },
        "data_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "tenant_id",
              "status"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/id"
              },
              "tenant_id": {
                "$ref": "#/$defs/id"
              },
              "status": {
                "type": "string",
                "enum": [
                  "planned",
                  "active",
                  "disabled",
                  "archived"
                ]
              }
            }
          }
        },
        "allowed_knowledge_scopes": {
          "$ref": "#/$defs/idArray"
        },
        "allowed_data_scopes": {
          "$ref": "#/$defs/idArray"
        },
        "allowed_memory_scopes": {
          "$ref": "#/$defs/idArray"
        }
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "role",
            "user",
            "service"
          ]
        },
        "id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "requestTenantContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "area_id",
        "hostname",
        "membership_id"
      ],
      "properties": {
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "area_id": {
          "$ref": "#/$defs/id"
        },
        "hostname": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "membership_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "taskSignals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_tags",
        "capability_hints",
        "available_inputs",
        "constraints",
        "classification_confidence",
        "ambiguous_task_types",
        "classification_reasons",
        "requires_human_review"
      ],
      "properties": {
        "domain_tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "capability_hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "available_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "classification_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "ambiguous_task_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "classification_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "requires_human_review": {
          "type": "boolean"
        }
      }
    },
    "idArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "objective",
        "risk_level",
        "signals"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "$ref": "#/$defs/id"
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "risk_level": {
          "$ref": "#/$defs/riskLevel"
        },
        "signals": {
          "$ref": "#/$defs/taskSignals"
        }
      }
    },
    "profileGeneration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "parent_profile_id"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "initial",
            "recomposition"
          ]
        },
        "parent_profile_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "environment",
        "principal",
        "requested_profile_generation",
        "task"
      ],
      "properties": {
        "contract_version": {
          "$ref": "#/$defs/semver"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "principal": {
          "$ref": "#/$defs/principal"
        },
        "tenant_context": {
          "$ref": "#/$defs/requestTenantContext"
        },
        "requested_profile_generation": {
          "$ref": "#/$defs/profileGeneration"
        },
        "task": {
          "$ref": "#/$defs/task"
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "registry_version",
        "composition_status",
        "candidate_modules",
        "applicable_policies",
        "allowed_knowledge_scopes",
        "allowed_data_scopes",
        "allowed_memory_scopes",
        "validation_requirements",
        "policy_decisions",
        "graph_validation"
      ],
      "properties": {
        "contract_version": {
          "$ref": "#/$defs/semver"
        },
        "registry_version": {
          "$ref": "#/$defs/semver"
        },
        "composition_status": {
          "type": "string",
          "enum": [
            "pending_registry_implementation",
            "ready",
            "denied",
            "invalid_request"
          ]
        },
        "candidate_modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleReference"
          }
        },
        "applicable_policies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleReference"
          }
        },
        "allowed_knowledge_scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleReference"
          }
        },
        "allowed_data_scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleReference"
          }
        },
        "allowed_memory_scopes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleReference"
          }
        },
        "validation_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleReference"
          }
        },
        "policy_decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policyDecision"
          }
        },
        "graph_validation": {
          "$ref": "#/$defs/graphValidation"
        },
        "tenant_authority": {
          "$ref": "#/$defs/tenantAuthority"
        }
      }
    }
  }
}
