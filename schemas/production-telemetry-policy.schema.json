{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:production-telemetry-policy:0.1.0",
  "title": "SCAS Production Telemetry Policy",
  "type": "object",
  "required": [
    "policy_id",
    "version",
    "environment",
    "notification_channels",
    "rules"
  ],
  "additionalProperties": false,
  "properties": {
    "policy_id": {
      "const": "production-telemetry-alerts"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "environment": {
      "enum": ["dev", "staging", "prod"]
    },
    "notification_channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "target", "secret_free"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "kind": {
            "enum": ["github-actions-summary", "operator-runbook", "external-pager"]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "secret_free": {
            "const": true
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "plane",
          "signal",
          "description",
          "severity",
          "operator",
          "threshold",
          "unit",
          "window",
          "source",
          "runbook",
          "missing_data_severity",
          "raw_data_policy"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "plane": {
            "enum": ["cloudflare-control-plane", "hetzner-runtime-plane", "release-gate"]
          },
          "signal": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": ["warning", "critical"]
          },
          "operator": {
            "enum": [">=", ">", "<=", "<", "=="]
          },
          "threshold": {
            "type": "number"
          },
          "unit": {
            "enum": ["count", "ratio", "seconds"]
          },
          "window": {
            "type": "string",
            "pattern": "^PT[0-9]+[MHS]$|^P[0-9]+D$"
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "runbook": {
            "type": "string",
            "pattern": "^docs/.+\\.md#.+$"
          },
          "missing_data_severity": {
            "enum": ["warning", "critical"]
          },
          "raw_data_policy": {
            "const": "aggregate_metadata_only"
          }
        }
      }
    }
  }
}
