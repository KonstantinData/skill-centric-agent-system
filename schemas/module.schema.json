{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:module:0.4.0",
  "title": "SCAS Registry Module Metadata",
  "description": "Metadata contract for a governed SCAS registry module. module.json is machine-readable selection and policy metadata; SKILL.md and bundled resources remain agent-readable entrypoints where applicable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "name",
    "version",
    "kind",
    "status",
    "description",
    "runtime_roles",
    "capability_class",
    "environments",
    "runtime_contract",
    "domain_tags",
    "task_signals",
    "triggers",
    "inputs",
    "outputs",
    "required_tools",
    "optional_tools",
    "knowledge_scopes",
    "data_scopes",
    "policies",
    "validators",
    "provenance",
    "selection",
    "selection_evidence",
    "tests"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "pattern": "^[.][.]/|^[.]/|^[^:/]+$"
    },
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "skill",
        "instruction",
        "tool",
        "knowledge_scope",
        "data_scope",
        "policy",
        "validator",
        "memory_scope"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "disabled"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "runtime_role": {
      "type": "string",
      "enum": [
        "runtime",
        "non-runtime",
        "shared"
      ]
    },
    "runtime_roles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "allowed"
      ],
      "properties": {
        "default": {
          "$ref": "#/$defs/runtimeRole"
        },
        "allowed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeRole"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "capability_class": {
      "type": "string",
      "enum": [
        "analysis",
        "planning",
        "execution",
        "retrieval",
        "validation",
        "policy",
        "instruction",
        "tool_access",
        "knowledge_access",
        "data_access",
        "memory_access",
        "context"
      ]
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "dev",
          "staging",
          "prod"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "skill_folder"
          ]
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        }
      }
    },
    "runtime_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_sealable",
        "requires_version_pin",
        "requires_handler_binding"
      ],
      "properties": {
        "profile_sealable": {
          "type": "boolean"
        },
        "requires_version_pin": {
          "type": "boolean"
        },
        "requires_handler_binding": {
          "type": "boolean"
        }
      }
    },
    "domain_tags": {
      "$ref": "#/$defs/stringArray"
    },
    "task_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_types",
        "risk_levels",
        "domains",
        "required_inputs",
        "phrases",
        "negative_phrases"
      ],
      "properties": {
        "task_types": {
          "$ref": "#/$defs/stringArray"
        },
        "risk_levels": {
          "$ref": "#/$defs/riskLevelArray"
        },
        "domains": {
          "$ref": "#/$defs/stringArray"
        },
        "required_inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "phrases": {
          "$ref": "#/$defs/stringArray"
        },
        "negative_phrases": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "triggers": {
      "$ref": "#/$defs/stringArray"
    },
    "inputs": {
      "$ref": "#/$defs/stringArray"
    },
    "outputs": {
      "$ref": "#/$defs/stringArray"
    },
    "required_tools": {
      "$ref": "#/$defs/stringArray"
    },
    "optional_tools": {
      "$ref": "#/$defs/stringArray"
    },
    "knowledge_scopes": {
      "$ref": "#/$defs/stringArray"
    },
    "data_scopes": {
      "$ref": "#/$defs/stringArray"
    },
    "policies": {
      "$ref": "#/$defs/stringArray"
    },
    "validators": {
      "$ref": "#/$defs/stringArray"
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "requires_all_policies"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "direct",
            "dependency_only"
          ]
        },
        "base_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "score_modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scoreModifier"
          }
        },
        "requires_all_policies": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "direct"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "required": [
              "base_score",
              "score_modifiers"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "dependency_only"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "base_score"
                  ]
                },
                {
                  "required": [
                    "score_modifiers"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "runtime",
        "fixtures"
      ],
      "properties": {
        "contract": {
          "$ref": "#/$defs/relativePathArray"
        },
        "runtime": {
          "$ref": "#/$defs/stringArray"
        },
        "fixtures": {
          "$ref": "#/$defs/relativePathArray"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "problem_statement",
        "acceptance_criteria",
        "source_of_truth",
        "rationale"
      ],
      "properties": {
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "person"
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "problem_statement": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_of_truth": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceOfTruth"
          },
          "minItems": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "requirement_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selection_evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "positive_selection": {
          "$ref": "#/$defs/evidenceArray"
        },
        "negative_selection": {
          "$ref": "#/$defs/evidenceArray"
        },
        "dependency_inclusion": {
          "$ref": "#/$defs/evidenceArray"
        },
        "no_direct_selection": {
          "$ref": "#/$defs/evidenceArray"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "skill"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "required": [
          "entrypoint",
          "runtime_role"
        ]
      },
      "else": {
        "not": {
          "required": [
            "entrypoint"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "selection": {
            "properties": {
              "mode": {
                "const": "direct"
              }
            },
            "required": [
              "mode"
            ]
          }
        },
        "required": [
          "selection"
        ]
      },
      "then": {
        "properties": {
          "selection_evidence": {
            "required": [
              "positive_selection",
              "negative_selection"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selection": {
            "properties": {
              "mode": {
                "const": "dependency_only"
              }
            },
            "required": [
              "mode"
            ]
          }
        },
        "required": [
          "selection"
        ]
      },
      "then": {
        "properties": {
          "selection_evidence": {
            "required": [
              "dependency_inclusion",
              "no_direct_selection"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "runtimeRole": {
      "type": "string",
      "enum": [
        "runtime",
        "non-runtime",
        "shared"
      ]
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^[A-Za-z]:"
          },
          {
            "pattern": "^/"
          },
          {
            "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*:"
          }
        ]
      }
    },
    "relativePathArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relativePath"
      },
      "uniqueItems": true
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "riskLevelArray": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      "uniqueItems": true
    },
    "scoreModifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "weight",
        "reason"
      ],
      "properties": {
        "signal": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceOfTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ref",
        "reason"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "repo_path",
            "adr",
            "notion_issue",
            "external_standard"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidenceArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selectionEvidence"
      },
      "minItems": 1
    },
    "selectionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture",
        "expectation",
        "reason"
      ],
      "properties": {
        "fixture": {
          "$ref": "#/$defs/relativePath"
        },
        "expectation": {
          "type": "string",
          "enum": [
            "selected",
            "rejected",
            "included_as_dependency",
            "not_directly_selected"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
