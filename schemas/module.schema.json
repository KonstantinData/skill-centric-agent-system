{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:liquisto:skill-centric-agent-system:schema:module:0.2.0",
  "title": "Selectable Module Metadata",
  "description": "Metadata contract for a selectable skill, instruction, tool, scope, policy, validator, or memory module.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "kind",
    "description",
    "capability_class",
    "domain_tags",
    "task_signals",
    "triggers",
    "inputs",
    "outputs",
    "required_tools",
    "optional_tools",
    "knowledge_scopes",
    "data_scopes",
    "policies",
    "validators",
    "selection",
    "tests"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "skill",
        "instruction",
        "tool",
        "knowledge_scope",
        "data_scope",
        "policy",
        "validator",
        "memory_scope"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "capability_class": {
      "type": "string",
      "enum": [
        "analysis",
        "planning",
        "execution",
        "retrieval",
        "validation",
        "policy",
        "instruction",
        "tool_access",
        "knowledge_access",
        "data_access",
        "memory_access",
        "context"
      ]
    },
    "domain_tags": {
      "$ref": "#/$defs/stringArray"
    },
    "task_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_types",
        "risk_levels",
        "domains",
        "required_inputs",
        "phrases",
        "negative_phrases"
      ],
      "properties": {
        "task_types": {
          "$ref": "#/$defs/stringArray"
        },
        "risk_levels": {
          "$ref": "#/$defs/riskLevelArray"
        },
        "domains": {
          "$ref": "#/$defs/stringArray"
        },
        "required_inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "phrases": {
          "$ref": "#/$defs/stringArray"
        },
        "negative_phrases": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "triggers": {
      "$ref": "#/$defs/stringArray"
    },
    "inputs": {
      "$ref": "#/$defs/stringArray"
    },
    "outputs": {
      "$ref": "#/$defs/stringArray"
    },
    "required_tools": {
      "$ref": "#/$defs/stringArray"
    },
    "optional_tools": {
      "$ref": "#/$defs/stringArray"
    },
    "knowledge_scopes": {
      "$ref": "#/$defs/stringArray"
    },
    "data_scopes": {
      "$ref": "#/$defs/stringArray"
    },
    "policies": {
      "$ref": "#/$defs/stringArray"
    },
    "validators": {
      "$ref": "#/$defs/stringArray"
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_score",
        "score_modifiers",
        "requires_all_policies"
      ],
      "properties": {
        "base_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "score_modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scoreModifier"
          }
        },
        "requires_all_policies": {
          "type": "boolean"
        }
      }
    },
    "tests": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "riskLevelArray": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      "uniqueItems": true
    },
    "scoreModifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "weight",
        "reason"
      ],
      "properties": {
        "signal": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
