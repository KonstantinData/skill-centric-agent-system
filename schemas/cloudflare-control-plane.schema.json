{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:cloudflare-control-plane:0.1.0",
  "title": "Cloudflare Control Plane Storage Contract",
  "description": "Recordset contract for Cloudflare D1 control-plane metadata and references to R2, Vectorize, KV, queues, and AI Gateway.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "environment",
    "records"
  ],
  "properties": {
    "contract_version": {
      "$ref": "#/$defs/semver"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "records": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modules",
        "module_versions",
        "module_selection_metadata",
        "module_dependencies",
        "knowledge_sources",
        "knowledge_documents",
        "knowledge_chunks",
        "memory_records",
        "scope_bindings",
        "policy_bindings",
        "tenants",
        "tenant_hostnames",
        "tenant_memberships",
        "tenant_role_bundles",
        "tenant_data_sources",
        "tenant_role_capability_grants",
        "tenant_role_data_source_grants",
        "ingestion_jobs",
        "audit_events"
      ],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/module"
          }
        },
        "module_versions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleVersion"
          }
        },
        "module_selection_metadata": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleSelectionMetadata"
          }
        },
        "module_dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/moduleDependency"
          }
        },
        "knowledge_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knowledgeSource"
          }
        },
        "knowledge_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knowledgeDocument"
          }
        },
        "knowledge_chunks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knowledgeChunk"
          }
        },
        "memory_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/memoryRecord"
          }
        },
        "scope_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scopeBinding"
          }
        },
        "policy_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policyBinding"
          }
        },
        "tenants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenant"
          }
        },
        "tenant_hostnames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenantHostname"
          }
        },
        "tenant_memberships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenantMembership"
          }
        },
        "tenant_role_bundles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenantRoleBundle"
          }
        },
        "tenant_data_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenantDataSource"
          }
        },
        "tenant_role_capability_grants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenantRoleCapabilityGrant"
          }
        },
        "tenant_role_data_source_grants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tenantRoleDataSourceGrant"
          }
        },
        "ingestion_jobs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ingestionJob"
          }
        },
        "audit_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/auditEvent"
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "secret"
      ]
    },
    "lifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "deleted"
      ]
    },
    "moduleKind": {
      "type": "string",
      "enum": [
        "skill",
        "instruction",
        "tool",
        "knowledge_scope",
        "data_scope",
        "memory_scope",
        "policy",
        "validator"
      ]
    },
    "capabilityClass": {
      "type": "string",
      "enum": [
        "analysis",
        "planning",
        "execution",
        "retrieval",
        "validation",
        "policy",
        "instruction",
        "tool_access",
        "knowledge_access",
        "data_access",
        "memory_access",
        "context"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "riskLevelArray": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      "uniqueItems": true
    },
    "scoreModifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "weight",
        "reason"
      ],
      "properties": {
        "signal": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "status",
        "current_version_id",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/moduleKind"
        },
        "status": {
          "$ref": "#/$defs/lifecycleStatus"
        },
        "current_version_id": {
          "$ref": "#/$defs/id"
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        },
        "updated_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "moduleVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "module_id",
        "version",
        "source_uri",
        "checksum",
        "selection_base_score",
        "created_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "module_id": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "source_uri": {
          "$ref": "#/$defs/uri"
        },
        "checksum": {
          "type": "string",
          "minLength": 1
        },
        "selection_base_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "moduleSelectionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "module_version_id",
        "description",
        "capability_class",
        "domain_tags",
        "task_types",
        "risk_levels",
        "task_domains",
        "required_inputs",
        "phrases",
        "negative_phrases",
        "triggers",
        "inputs",
        "outputs",
        "score_modifiers",
        "requires_all_policies"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "module_version_id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "capability_class": {
          "$ref": "#/$defs/capabilityClass"
        },
        "domain_tags": {
          "$ref": "#/$defs/stringArray"
        },
        "task_types": {
          "$ref": "#/$defs/stringArray"
        },
        "risk_levels": {
          "$ref": "#/$defs/riskLevelArray"
        },
        "task_domains": {
          "$ref": "#/$defs/stringArray"
        },
        "required_inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "phrases": {
          "$ref": "#/$defs/stringArray"
        },
        "negative_phrases": {
          "$ref": "#/$defs/stringArray"
        },
        "triggers": {
          "$ref": "#/$defs/stringArray"
        },
        "inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "outputs": {
          "$ref": "#/$defs/stringArray"
        },
        "score_modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scoreModifier"
          }
        },
        "requires_all_policies": {
          "type": "boolean"
        }
      }
    },
    "moduleDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "module_version_id",
        "dependency_kind",
        "dependency_id",
        "is_required"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "module_version_id": {
          "$ref": "#/$defs/id"
        },
        "dependency_kind": {
          "$ref": "#/$defs/moduleKind"
        },
        "dependency_id": {
          "$ref": "#/$defs/id"
        },
        "is_required": {
          "type": "boolean"
        }
      }
    },
    "knowledgeSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "source_type",
        "uri",
        "owner",
        "sensitivity",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "repo",
            "notion",
            "r2",
            "url",
            "manual"
          ]
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "sensitivity": {
          "$ref": "#/$defs/sensitivity"
        },
        "status": {
          "$ref": "#/$defs/lifecycleStatus"
        }
      }
    },
    "knowledgeDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_id",
        "version",
        "content_uri",
        "manifest_uri",
        "checksum",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "source_id": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "content_uri": {
          "$ref": "#/$defs/uri"
        },
        "manifest_uri": {
          "$ref": "#/$defs/uri"
        },
        "checksum": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/lifecycleStatus"
        }
      }
    },
    "knowledgeChunk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "document_id",
        "chunk_index",
        "content_uri",
        "vector_id",
        "scope_id",
        "token_count"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "document_id": {
          "$ref": "#/$defs/id"
        },
        "chunk_index": {
          "type": "integer",
          "minimum": 0
        },
        "content_uri": {
          "$ref": "#/$defs/uri"
        },
        "vector_id": {
          "$ref": "#/$defs/id"
        },
        "scope_id": {
          "$ref": "#/$defs/id"
        },
        "token_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "memoryRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "memory_scope_id",
        "version",
        "content_uri",
        "manifest_uri",
        "source_run_id",
        "source_profile_id",
        "sensitivity",
        "retention_policy",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "memory_scope_id": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "content_uri": {
          "$ref": "#/$defs/uri"
        },
        "manifest_uri": {
          "$ref": "#/$defs/uri"
        },
        "source_run_id": {
          "$ref": "#/$defs/id"
        },
        "source_profile_id": {
          "$ref": "#/$defs/id"
        },
        "sensitivity": {
          "$ref": "#/$defs/sensitivity"
        },
        "retention_policy": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "$ref": "#/$defs/lifecycleStatus"
        }
      }
    },
    "scopeBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope_id",
        "scope_kind",
        "principal_kind",
        "principal_id",
        "policy_id",
        "effect"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "scope_id": {
          "$ref": "#/$defs/id"
        },
        "scope_kind": {
          "type": "string",
          "enum": [
            "knowledge_scope",
            "data_scope",
            "memory_scope"
          ]
        },
        "principal_kind": {
          "type": "string",
          "enum": [
            "role",
            "user",
            "service"
          ]
        },
        "principal_id": {
          "$ref": "#/$defs/id"
        },
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "effect": {
          "$ref": "#/$defs/policyEffect"
        }
      }
    },
    "policyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "policy_id",
        "target_kind",
        "target_id",
        "effect",
        "priority"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "policy_id": {
          "$ref": "#/$defs/id"
        },
        "target_kind": {
          "type": "string",
          "enum": [
            "module",
            "knowledge_source",
            "knowledge_document",
            "memory_record",
            "scope"
          ]
        },
        "target_id": {
          "$ref": "#/$defs/id"
        },
        "effect": {
          "$ref": "#/$defs/policyEffect"
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "policyEffect": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "area_id",
        "display_name",
        "legal_name",
        "status",
        "default_locale",
        "contact_email",
        "contact_phone",
        "contact_website",
        "memory_area_brain_id",
        "shared_promotion_allowed",
        "knowledge_scope_id",
        "policy_bundle",
        "validators",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "area_id": {
          "$ref": "#/$defs/id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "legal_name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "setup",
            "active",
            "disabled",
            "archived"
          ]
        },
        "default_locale": {
          "type": "string",
          "minLength": 1
        },
        "contact_email": {
          "type": "string",
          "format": "email"
        },
        "contact_phone": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "contact_website": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "memory_area_brain_id": {
          "$ref": "#/$defs/id"
        },
        "shared_promotion_allowed": {
          "type": "boolean",
          "const": false
        },
        "knowledge_scope_id": {
          "$ref": "#/$defs/id"
        },
        "policy_bundle": {
          "$ref": "#/$defs/stringArray"
        },
        "validators": {
          "$ref": "#/$defs/stringArray"
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        },
        "updated_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "tenantHostname": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tenant_id",
        "hostname",
        "purpose",
        "expected_origin",
        "cloudflare_proxy_expected"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "hostname": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "enum": [
            "primary-ui",
            "api",
            "admin"
          ]
        },
        "expected_origin": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "cloudflare_proxy_expected": {
          "type": "boolean"
        }
      }
    },
    "tenantMembership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tenant_id",
        "principal_id",
        "status",
        "role_ids",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "principal_id": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "type": "string",
          "enum": [
            "invited",
            "active",
            "disabled"
          ]
        },
        "role_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        },
        "updated_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "tenantRoleBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tenant_id",
        "display_name",
        "role_type",
        "assignable_to_users",
        "derived_skills",
        "derived_workflows",
        "derived_tools",
        "derived_policies",
        "derived_validators"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "role_type": {
          "type": "string",
          "enum": [
            "system",
            "tenant-custom"
          ]
        },
        "assignable_to_users": {
          "type": "boolean"
        },
        "derived_skills": {
          "$ref": "#/$defs/stringArray"
        },
        "derived_workflows": {
          "$ref": "#/$defs/stringArray"
        },
        "derived_tools": {
          "$ref": "#/$defs/stringArray"
        },
        "derived_policies": {
          "$ref": "#/$defs/stringArray"
        },
        "derived_validators": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "tenantDataSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tenant_id",
        "source_type",
        "display_name",
        "access_modes",
        "status",
        "sensitivity"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "github_repository",
            "notion_page_tree",
            "google_drive_folder",
            "sharepoint_site",
            "hubspot_account",
            "website",
            "database",
            "other"
          ]
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "access_modes": {
          "$ref": "#/$defs/stringArray"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "active",
            "disabled",
            "archived"
          ]
        },
        "sensitivity": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        }
      }
    },
    "tenantRoleCapabilityGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tenant_id",
        "role_bundle_id",
        "capability_id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "role_bundle_id": {
          "$ref": "#/$defs/id"
        },
        "capability_id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "tenantRoleDataSourceGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tenant_id",
        "role_bundle_id",
        "data_source_id",
