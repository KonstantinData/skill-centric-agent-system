{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:knowledge-quality-policy:0.1.0",
  "title": "SCAS Knowledge And Data Quality Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "policy_id",
    "applies_to",
    "source_quality_rules",
    "ingestion_controls",
    "acceptance_gates"
  ],
  "properties": {
    "contract_version": {
      "$ref": "#/$defs/semver"
    },
    "policy_id": {
      "$ref": "#/$defs/id"
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "knowledge_source",
          "knowledge_document",
          "memory_record",
          "data_scope"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_quality_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_metadata",
        "allowed_source_types",
        "allowed_sensitivities",
        "minimum_confidence_weight",
        "freshness_review_days"
      ],
      "properties": {
        "required_metadata": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "allowed_source_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "repo",
              "notion",
              "r2",
              "url",
              "manual"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowed_sensitivities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sensitivity"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "minimum_confidence_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshness_review_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "ingestion_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cloudflare_rejects_raw_runtime_artifacts",
        "secret_sensitivity_allowed",
        "requires_owner",
        "requires_scope_binding",
        "requires_retention_policy"
      ],
      "properties": {
        "cloudflare_rejects_raw_runtime_artifacts": {
          "type": "boolean",
          "const": true
        },
        "secret_sensitivity_allowed": {
          "type": "boolean",
          "const": false
        },
        "requires_owner": {
          "type": "boolean",
          "const": true
        },
        "requires_scope_binding": {
          "type": "boolean",
          "const": true
        },
        "requires_retention_policy": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "acceptance_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "severity",
          "condition",
          "failure_action"
        ],
        "properties": {
          "gate_id": {
            "$ref": "#/$defs/id"
          },
          "severity": {
            "type": "string",
            "enum": [
              "mandatory",
              "guardrail",
              "quality"
            ]
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "failure_action": {
            "type": "string",
            "enum": [
              "block",
              "warn",
              "request_review"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "secret"
      ]
    },
    "nonEmptyStringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
