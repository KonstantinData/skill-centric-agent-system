        },
        "source_step_id": {
          "$ref": "#/$defs/id"
        },
        "target_memory_scope_id": {
          "$ref": "#/$defs/id"
        },
        "candidate_class": {
          "$ref": "#/$defs/memoryCandidateClass"
        },
        "classification_reason": {
          "type": "string",
          "minLength": 1
        },
        "content_uri": {
          "$ref": "#/$defs/uri"
        },
        "sensitivity": {
