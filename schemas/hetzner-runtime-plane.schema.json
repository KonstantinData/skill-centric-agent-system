        "run_id",
        "step_id",
        "validator_id",
        "status",
        "findings_uri",
        "created_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "run_id": {
          "$ref": "#/$defs/id"
        },
        "step_id": {
