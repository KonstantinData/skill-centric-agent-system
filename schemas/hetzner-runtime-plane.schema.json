{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scas:schema:hetzner-runtime-plane:0.2.0",
  "title": "Hetzner Runtime Plane Storage Contract",
  "description": "Recordset contract for Hetzner runtime storage covering runs, steps, flight-recorder events, checkpoints, tool invocations, validation results, artifacts, and memory candidates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "environment",
    "records"
  ],
  "properties": {
    "contract_version": {
      "$ref": "#/$defs/semver"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "records": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_queue_items",
        "runtime_run_attempts",
        "runtime_run_claims",
        "runtime_dead_letters",
        "runtime_quota_reservations",
        "runtime_runs",
        "runtime_steps",
        "runtime_events",
        "runtime_checkpoints",
        "tool_invocations",
        "validation_results",
        "memory_candidates"
      ],
      "properties": {
        "runtime_queue_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeQueueItem"
          }
        },
        "runtime_run_attempts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeRunAttempt"
          }
        },
        "runtime_run_claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeRunClaim"
          }
        },
        "runtime_dead_letters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeDeadLetter"
          }
        },
        "runtime_quota_reservations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeQuotaReservation"
          }
        },
        "runtime_runs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeRun"
          }
        },
        "runtime_steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeStep"
          }
        },
        "runtime_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeEvent"
          }
        },
        "runtime_checkpoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runtimeCheckpoint"
          }
        },
        "tool_invocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/toolInvocation"
          }
        },
        "validation_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validationResult"
          }
        },
        "memory_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/memoryCandidate"
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableDateTime": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "nullableUri": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "nullableSha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "nullableNonNegativeInteger": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "secret"
      ]
    },
    "memoryCandidateClass": {
      "type": "string",
      "enum": [
        "procedural_lesson",
        "task_subject_fact",
        "runtime_evidence",
        "knowledge_record_proposal",
        "rejected"
      ]
    },
    "runtimeStatus": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "runtimeQueueStatus": {
      "type": "string",
      "enum": [
        "queued",
        "claiming",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "retry_scheduled",
        "dead_lettered"
      ]
    },
    "stopReason": {
      "type": "string",
      "enum": [
        "completed",
        "max_tokens",
        "max_duration",
        "max_tool_calls",
        "max_data_reads",
        "max_memory_ops",
        "max_recompositions",
        "policy_denied",
        "validator_failed",
        "tool_error",
        "cancelled",
        "needs_recomposition",
        "composer_failure",
        "runtime_error"
      ]
    },
    "nullableStopReason": {
      "oneOf": [
        {
          "$ref": "#/$defs/stopReason"
        },
        {
          "type": "null"
        }
      ]
    },
    "eventType": {
      "type": "string",
      "enum": [
        "task_intake_normalized",
        "task_analyzed",
        "candidates_discovered",
        "candidates_scored",
        "policies_evaluated",
        "graph_validated",
        "profile_emitted",
        "profile_validated",
        "runtime_started",
        "access_attempted",
        "validator_executed",
        "runtime_completed",
        "runtime_failed",
        "runtime_cancelled",
        "tenant_throttled",
        "quota_reserved",
        "quota_exhausted",
        "step_started",
        "step_completed",
        "tool_invocation_started",
        "tool_invocation_completed",
        "budget_exhausted",
        "checkpoint_created",
        "recomposition_requested"
      ]
    },
    "actorRole": {
      "type": "string",
      "enum": [
        "context_manager",
        "planner",
        "executor",
        "validator",
        "policy_engine",
        "quota_manager",
        "runtime",
        "composer"
      ]
    },
    "runtimeQueueItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "task_id",
        "tenant_id",
        "area_id",
        "environment",
        "queue_name",
        "status",
        "priority",
        "scheduled_at",
        "attempts",
        "max_attempts",
        "claimed_by",
        "claimed_at",
        "claimed_until",
        "lease_expires_at",
        "heartbeat_at",
        "attempt_id",
        "task_payload_uri",
        "composition_context_uri",
        "run_id",
        "last_error",
        "idempotency_key",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "task_id": {
          "$ref": "#/$defs/id"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "area_id": {
          "$ref": "#/$defs/id"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "queue_name": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "$ref": "#/$defs/runtimeQueueStatus"
        },
        "priority": {
          "type": "integer"
        },
        "scheduled_at": {
          "$ref": "#/$defs/dateTime"
        },
        "attempts": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "max_attempts": {
          "$ref": "#/$defs/positiveInteger"
        },
        "claimed_by": {
          "$ref": "#/$defs/nullableString"
        },
        "claimed_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "claimed_until": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "lease_expires_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "heartbeat_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "attempt_id": {
          "$ref": "#/$defs/nullableId"
        },
        "task_payload_uri": {
          "$ref": "#/$defs/uri"
        },
        "composition_context_uri": {
          "$ref": "#/$defs/nullableUri"
        },
        "run_id": {
          "$ref": "#/$defs/nullableId"
        },
        "last_error": {
          "$ref": "#/$defs/nullableString"
        },
        "idempotency_key": {
          "$ref": "#/$defs/uri"
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        },
        "updated_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "runtimeRunAttempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "queue_id",
        "run_id",
        "tenant_id",
        "attempt_number",
        "status",
        "started_at",
        "completed_at",
        "stop_reason",
        "profile_id",
        "profile_sha256"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "queue_id": {
          "$ref": "#/$defs/id"
        },
        "run_id": {
          "$ref": "#/$defs/nullableId"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "attempt_number": {
          "$ref": "#/$defs/positiveInteger"
        },
        "status": {
          "$ref": "#/$defs/runtimeQueueStatus"
        },
        "started_at": {
          "$ref": "#/$defs/dateTime"
        },
        "completed_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "stop_reason": {
          "$ref": "#/$defs/nullableString"
        },
        "profile_id": {
          "$ref": "#/$defs/nullableId"
        },
        "profile_sha256": {
          "$ref": "#/$defs/nullableSha256"
        }
      }
    },
    "runtimeRunClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "queue_id",
        "worker_id",
        "tenant_id",
        "claimed_at",
        "claimed_until",
        "heartbeat_at",
        "released_at",
        "release_reason"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "queue_id": {
          "$ref": "#/$defs/id"
        },
        "worker_id": {
          "$ref": "#/$defs/uri"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "claimed_at": {
          "$ref": "#/$defs/dateTime"
        },
        "claimed_until": {
          "$ref": "#/$defs/dateTime"
        },
        "heartbeat_at": {
          "$ref": "#/$defs/dateTime"
        },
        "released_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "release_reason": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "runtimeDeadLetter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "queue_id",
        "run_id",
        "attempt_id",
        "tenant_id",
        "error_type",
        "error_message",
        "created_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "queue_id": {
          "$ref": "#/$defs/id"
        },
        "run_id": {
          "$ref": "#/$defs/nullableId"
        },
        "attempt_id": {
          "$ref": "#/$defs/nullableId"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "error_type": {
          "$ref": "#/$defs/uri"
        },
        "error_message": {
          "$ref": "#/$defs/uri"
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "runtimeQuotaReservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "queue_id",
        "run_id",
        "tenant_id",
        "quota_window",
        "reserved_tokens",
        "reserved_tool_calls",
        "status",
        "created_at",
        "finalized_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "queue_id": {
          "$ref": "#/$defs/id"
        },
        "run_id": {
          "$ref": "#/$defs/nullableId"
        },
        "tenant_id": {
          "$ref": "#/$defs/id"
        },
        "quota_window": {
          "$ref": "#/$defs/uri"
        },
        "reserved_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "reserved_tool_calls": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "status": {
          "type": "string",
          "enum": [
            "reserved",
            "finalized",
            "refunded"
          ]
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        },
        "finalized_at": {
          "$ref": "#/$defs/nullableDateTime"
        }
      }
    },
    "runtimePhase": {
      "type": "string",
      "enum": [
        "task_intake",
        "analysis",
        "composition",
        "context",
        "planner",
        "executor",
        "validator",
        "finalization"
      ]
    },
    "runtimeRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "task_id",
        "profile_id",
        "profile_version",
        "status",
        "started_at",
        "completed_at",
        "artifact_root_uri",
        "token_budget_total",
        "tokens_used_total",
        "stop_reason",
        "profile_artifact_uri",
        "profile_sha256",
        "profile_generation",
        "parent_profile_id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "task_id": {
          "$ref": "#/$defs/id"
        },
        "profile_id": {
          "$ref": "#/$defs/id"
        },
        "profile_version": {
          "$ref": "#/$defs/semver"
        },
        "status": {
          "$ref": "#/$defs/runtimeStatus"
        },
        "started_at": {
          "$ref": "#/$defs/dateTime"
        },
        "completed_at": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "artifact_root_uri": {
          "$ref": "#/$defs/uri"
        },
        "token_budget_total": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "tokens_used_total": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "stop_reason": {
          "$ref": "#/$defs/nullableStopReason"
        },
        "profile_artifact_uri": {
          "$ref": "#/$defs/nullableUri"
        },
        "profile_sha256": {
          "$ref": "#/$defs/nullableSha256"
        },
        "profile_generation": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "parent_profile_id": {
          "$ref": "#/$defs/nullableId"
        }
      }
    },
    "runtimeStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "step_index",
        "kind",
        "status",
        "started_at",
        "completed_at",
        "stop_reason",
        "token_budget",
