        },
        "idempotency_key": {
          "$ref": "#/$defs/uri"
        },
        "created_at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "runtimeCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "step_id",
        "checkpoint_index",
        "phase",
        "state_uri",
        "tokens_used_total",
        "created_at"
      ],
      "properties": {
        "id": {
