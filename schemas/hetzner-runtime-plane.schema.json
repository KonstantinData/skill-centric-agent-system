    "memoryCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "profile_id",
        "source_step_id",
        "target_memory_scope_id",
        "candidate_class",
        "classification_reason",
        "content_uri",
        "sensitivity",
        "retention_policy",
        "validator_status",
        "validator_id",
        "policy_status",
        "policy_id",
        "created_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
