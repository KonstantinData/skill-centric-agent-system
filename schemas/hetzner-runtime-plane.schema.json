          "$ref": "#/$defs/id"
        },
        "tool_name": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "$ref": "#/$defs/runtimeStatus"
        },
        "input_uri": {
          "$ref": "#/$defs/uri"
        },
