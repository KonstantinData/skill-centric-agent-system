          "$ref": "#/$defs/nullableStopReason"
        },
        "token_budget": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "tokens_used": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "idempotency_key": {
          "$ref": "#/$defs/uri"
        },
        "attempt": {
          "$ref": "#/$defs/positiveInteger"
        }
      }
    },
    "runtimeEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "step_id",
        "event_index",
        "event_type",
        "actor_role",
        "planned_action_uri",
        "execution_uri",
        "result_uri",
        "stop_reason",
        "idempotency_key",
        "created_at"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "run_id": {
          "$ref": "#/$defs/id"
        },
        "step_id": {
          "$ref": "#/$defs/nullableId"
        },
        "event_index": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "event_type": {
          "$ref": "#/$defs/eventType"
        },
        "actor_role": {
          "$ref": "#/$defs/actorRole"
        },
        "planned_action_uri": {
          "$ref": "#/$defs/nullableUri"
        },
        "execution_uri": {
