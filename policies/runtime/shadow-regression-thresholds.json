{
  "contract_version": "0.1.0",
  "policy_id": "fsg-08-shadow-regression-thresholds",
  "owner": "@KonstantinData",
  "shadow_report_source": "scripts/operations/evaluate_shadow_profile_versions.py",
  "delta_thresholds": {
    "abstention_delta_max_abs": 0.2,
    "mixed_profile_rate_delta_max_abs": 0.1,
    "safety_false_negative_delta_max": 0.6,
    "decision_change_rate_max": 0.6
  },
  "selection_drift_policy": {
    "fail_closed_on_missing_change_type": true,
    "default_thresholds": {
      "precision_delta_min": -0.25,
      "recall_delta_min": -0.25
    },
    "by_change_type": {
      "code-review": {
        "precision_delta_min": -0.25,
        "recall_delta_min": -0.3
      },
      "policy-change": {
        "precision_delta_min": -0.25,
        "recall_delta_min": -0.6
      },
      "data-update": {
        "precision_delta_min": -0.25,
        "recall_delta_min": -0.25
      },
      "runtime-hotfix": {
        "precision_delta_min": -0.25,
        "recall_delta_min": -0.25
      }
    }
  }
}
