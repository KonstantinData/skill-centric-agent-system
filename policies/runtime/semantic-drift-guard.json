        "environment": "staging",
        "risk_level": "medium",
        "workflow_id": "runtime-preflight-required",
        "principal_role": "repository-maintainer",
        "task_type": "production-preflight"
      },
      "forbidden_generalization": {
        "environment": "prod",
        "risk_level": "high",
        "workflow_id": "runtime-preflight-required",
        "principal_role": "repository-maintainer",
        "task_type": "production-preflight",
        "authority_delta": [
