{
  "contract_version": "0.1.0",
  "guard_id": "semantic-drift-guard",
  "owner": "@KonstantinData",
  "authority_invariant": "learned_context_not_authority",
  "default_on_match": "needs_human_review",
  "influence_classes": [
    {
      "id": "retrieval_only",
      "description": "Learned context may affect retrieval ordering only.",
      "max_automatic_effect": "retrieval_ordering",
      "automatic_authority_delta_allowed": false
    },
    {
      "id": "planner_hint",
      "description": "Learned context may shape a plan without changing executable authority.",
      "max_automatic_effect": "planner_hint",
      "automatic_authority_delta_allowed": false
    },
    {
      "id": "analyzer_prior",
      "description": "Learned context may bias task classification and risk hints without granting capabilities.",
      "max_automatic_effect": "analyzer_prior",
      "automatic_authority_delta_allowed": false
    },
    {
      "id": "composer_candidate_bias",
      "description": "Learned context may adjust candidate ranking while policy gates remain authoritative.",
      "max_automatic_effect": "candidate_ranking",
      "automatic_authority_delta_allowed": false
    },
    {
      "id": "golden_workflow_proposal",
      "description": "Learned context may propose a reviewed golden workflow update.",
      "max_automatic_effect": "proposal_only",
      "automatic_authority_delta_allowed": false
    },
    {
      "id": "policy_change_proposal",
      "description": "Learned context may propose a reviewed policy change.",
      "max_automatic_effect": "proposal_only",
      "automatic_authority_delta_allowed": false
    },
    {
      "id": "scoped_exception_proposal",
      "description": "Learned context may propose a reviewed, scoped, expiring exception.",
      "max_automatic_effect": "proposal_only",
      "automatic_authority_delta_allowed": false
    }
  ],
  "contrastive_pairs": [
    {
      "pair_id": "staging-budget-gap-must-not-generalize-to-prod",
