{
  "name": "skill-centric-agent-system",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/khh-mobile-proof"
  ],
  "scripts": {
    "worker:typecheck": "tsc --noEmit -p workers/control-api/tsconfig.json",
    "worker:test": "vitest run --config workers/control-api/vitest.config.ts",
    "worker:types": "wrangler types workers/control-api/src/worker-configuration.d.ts --include-runtime false --config workers/control-api/wrangler.toml",
    "worker:check": "wrangler deploy --dry-run --config workers/control-api/wrangler.toml",
    "worker:deploy:dev": "wrangler deploy --config workers/control-api/wrangler.toml",
    "dkh-crm:lint": "npm --prefix apps/dkh-crm run lint",
    "dkh-crm:build": "npm --prefix apps/dkh-crm run build",
    "dkh-crm:check": "npm run dkh-crm:lint && npm run dkh-crm:build",
    "liquisto-workbench:lint": "npm --prefix apps/liquisto-workbench run lint",
    "liquisto-workbench:build": "npm --prefix apps/liquisto-workbench run build",
    "liquisto-workbench:check": "npm run liquisto-workbench:lint && npm run liquisto-workbench:build",
    "khh-workbench:lint": "npm --prefix apps/khh-workbench run lint",
    "khh-workbench:build": "npm --prefix apps/khh-workbench run build",
    "khh-mobile-proof:check": "npm --prefix apps/khh-mobile-proof run check",
    "khh-workbench:check": "npm run khh-workbench:lint && npm run khh-workbench:build && npm run khh-mobile-proof:check"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "4.20260629.1",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
