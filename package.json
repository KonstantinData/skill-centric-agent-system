{
  "name": "skill-centric-agent-system",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "worker:typecheck": "tsc --noEmit -p workers/control-api/tsconfig.json",
    "worker:test": "vitest run --config workers/control-api/vitest.config.ts",
    "worker:types": "wrangler types workers/control-api/src/worker-configuration.d.ts --include-runtime false --config workers/control-api/wrangler.toml",
    "worker:check": "wrangler deploy --dry-run --config workers/control-api/wrangler.toml",
    "worker:deploy:dev": "wrangler deploy --config workers/control-api/wrangler.toml",
    "dkh-crm:lint": "npm --prefix apps/dkh-crm run lint",
    "dkh-crm:build": "npm --prefix apps/dkh-crm run build",
    "dkh-crm:check": "npm run dkh-crm:lint && npm run dkh-crm:build"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.17",
    "@cloudflare/workers-types": "4.20260621.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
