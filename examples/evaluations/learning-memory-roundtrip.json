    "expected_candidate": {
      "target_memory_scope_id": "mod-project-memory",
      "sensitivity": "internal",
      "retention_policy": "project-memory-180d",
      "validator_status": "approved",
      "policy_status": "approved"
    }
  },
  "consumer": {
    "authorized_retrieval_request": {
      "contract_version": "0.1.0",
