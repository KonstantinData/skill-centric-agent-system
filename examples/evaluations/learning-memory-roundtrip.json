    "unauthorized_retrieval_request": {
      "contract_version": "0.1.0",
      "principal": {
        "kind": "role",
        "id": "guest"
      },
      "query": "runtime reconstruction decisions",
      "knowledge_scope_ids": [
        "mod-architecture-docs"
      ],
      "memory_scope_ids": [
        "mod-project-memory"
      ],
      "top_k": 5
    }
  },
  "expected_negative_behavior": "The unauthorized retrieval request returns no memory records because D1 scope bindings do not allow the guest principal."
