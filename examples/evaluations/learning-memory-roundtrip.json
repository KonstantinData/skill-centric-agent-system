        "kind": "role",
        "id": "repository-maintainer"
      },
      "query": "runtime reconstruction decisions",
      "knowledge_scope_ids": [
        "mod-architecture-docs"
      ],
      "memory_scope_ids": [
        "mod-project-memory"
      ],
