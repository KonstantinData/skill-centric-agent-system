{
  "contract_version": "0.1.0",
  "kind": "start_run_request",
  "environment": "dev",
  "task": {
    "id": "task-code-review-latest-commit",
    "task_type": "code-review"
  },
  "storage": {
    "mode": "postgres",
    "database_url_env": "SCAS_RUNTIME_DATABASE_URL"
  },
  "execution": {
    "artifact_root": "/opt/scas/runtime",
    "repository_root": "/workspace/repository",
    "run_immediately": true
  }
}
