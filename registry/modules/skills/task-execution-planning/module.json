{
  "$schema": "../../../../schemas/module.schema.json",
  "schema_version": "0.1.0",
  "name": "task-execution-planning",
  "version": "0.1.0",
  "kind": "skill",
  "status": "active",
  "description": "Plan and summarize conservative repository task execution using read-only inspection tools.",
  "runtime_role": "runtime",
  "runtime_roles": {
    "default": "runtime",
    "allowed": [
      "runtime"
    ]
  },
  "capability_class": "planning",
  "environments": [
    "dev",
    "staging",
    "prod"
  ],
  "entrypoint": {
    "type": "skill_folder",
    "path": "SKILL.md"
  },
  "runtime_contract": {
    "profile_sealable": true,
    "requires_version_pin": true,
    "requires_handler_binding": true
  },
  "domain_tags": [
    "task-execution",
    "software-engineering",
    "repository"
  ],
  "task_signals": {
    "task_types": [
      "task-execution"
    ],
    "risk_levels": [
      "low",
      "medium",
      "high"
    ],
    "domains": [
      "task-execution",
      "software-engineering",
      "repository"
    ],
    "required_inputs": [
      "repository"
    ],
    "phrases": [
      "implement",
      "fix",
      "update",
      "refactor",
      "migrate"
    ],
    "negative_phrases": [
      "delete production",
      "destroy",
      "explain",
      "how do i",
      "reset production",
      "stack overflow",
      "what causes",
      "why does"
    ]
  },
  "triggers": [
    "implement",
    "fix",
    "update",
    "refactor",
    "migrate"
  ],
  "inputs": [
    "repository"
  ],
  "outputs": [
    "execution-plan",
    "execution-summary"
  ],
  "required_tools": [
    "filesystem-read",
    "filesystem-list",
    "git-read"
  ],
  "optional_tools": [
    "test-runner"
  ],
  "knowledge_scopes": [
    "architecture-docs",
    "coding-guidelines"
  ],
  "data_scopes": [
    "repository-readonly"
  ],
  "policies": [
    "no-destructive-commands"
  ],
  "validators": [
    "task-execution-output-contract"
  ],
  "selection": {
    "base_score": 0.7,
    "score_modifiers": [
      {
        "signal": "task_type:task-execution",
        "weight": 0.18,
        "reason": "Task execution requests need bounded planning and read-only repository inspection."
      },
      {
        "signal": "input:repository",
        "weight": 0.08,
        "reason": "Repository task execution is more reliable when repository context is available."
      },
      {
        "signal": "phrase:destroy",
        "weight": -0.4,
        "reason": "Destructive requests must not select the conservative execution module."
      },
      {
        "signal": "phrase:how do i",
        "weight": -0.16,
        "reason": "How-to troubleshooting phrasing needs research unless explicit repository mutation remains after analysis."
      },
      {
        "signal": "phrase:why does",
        "weight": -0.16,
        "reason": "Causal troubleshooting questions should not overgrant execution planning."
      },
      {
        "signal": "phrase:stack overflow",
        "weight": -0.12,
        "reason": "Stack Overflow-like questions are usually explanatory research tasks, not repository execution."
      }
    ],
    "requires_all_policies": true
  },
  "tests": {
    "contract": [],
    "runtime": [
      "task-execution-planning-positive",
      "task-execution-planning-denies-destructive"
    ],
    "fixtures": []
  }
}
